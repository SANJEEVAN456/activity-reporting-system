NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGO_DIRECT_URI=
JWT_SECRET=replace-with-a-long-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
ADMIN_EMAIL=replace-with-admin-email
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_RESET_SECRET=replace-with-random-admin-reset-secret
ADMIN_REGISTER_CODE=replace-with-random-admin-register-code
UPLOAD_DIR=uploads
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
